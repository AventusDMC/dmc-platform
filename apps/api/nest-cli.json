{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "quotes/**/*.hbs",
        "outDir": "dist"
      },
      {
        "include": "quotes/**/*.css",
        "outDir": "dist"
      },
      {
        "include": "quotes/**/*.woff2",
        "outDir": "dist"
      }
    ],
    "watchAssets": true
  }
}
