generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                    String                @id @default(uuid()) @db.Uuid
  quoteId               String                @unique @db.Uuid
  acceptedVersionId     String                @unique @db.Uuid
  bookingType           BookingType           @default(FIT)
  status                BookingStatus         @default(draft)
  clientInvoiceStatus   ClientInvoiceStatus   @default(unbilled)
  supplierPaymentStatus SupplierPaymentStatus @default(unpaid)
  statusNote            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bookingRef            String
  snapshotJson          Json
  clientSnapshotJson    Json
  brandSnapshotJson     Json?
  contactSnapshotJson   Json
  itinerarySnapshotJson Json
  pricingSnapshotJson   Json
  adults                Int
  children              Int
  roomCount             Int
  nightCount            Int
  accessToken           String                @unique
  acceptedVersion       QuoteVersion          @relation("BookingAcceptedVersion", fields: [acceptedVersionId], references: [id])
  quote                 Quote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  services              BookingService[]
  auditLogs             BookingAuditLog[]
  passengers            BookingPassenger[]
  roomingEntries        BookingRoomingEntry[]

  @@index([bookingType])
  @@index([clientInvoiceStatus])
  @@index([supplierPaymentStatus])
  @@map("bookings")
}

model BookingPassenger {
  id                 String                     @id @default(uuid()) @db.Uuid
  bookingId          String                     @db.Uuid
  firstName          String
  lastName           String
  title              String?
  isLead             Boolean                    @default(false)
  notes              String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomingAssignments BookingRoomingAssignment[]

  @@index([bookingId, isLead])
  @@map("booking_passengers")
}

model BookingRoomingEntry {
  id          String                     @id @default(uuid()) @db.Uuid
  bookingId   String                     @db.Uuid
  roomType    String?
  occupancy   BookingRoomOccupancy       @default(unknown)
  notes       String?
  sortOrder   Int                        @default(0)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  booking     Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assignments BookingRoomingAssignment[]

  @@index([bookingId, sortOrder])
  @@map("booking_rooming_entries")
}

model BookingRoomingAssignment {
  id                    String              @id @default(uuid()) @db.Uuid
  bookingRoomingEntryId String              @db.Uuid
  bookingPassengerId    String              @db.Uuid
  createdAt             DateTime            @default(now())
  bookingRoomingEntry   BookingRoomingEntry @relation(fields: [bookingRoomingEntryId], references: [id], onDelete: Cascade)
  bookingPassenger      BookingPassenger    @relation(fields: [bookingPassengerId], references: [id], onDelete: Cascade)

  @@unique([bookingRoomingEntryId, bookingPassengerId])
  @@index([bookingPassengerId])
  @@map("booking_rooming_assignments")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hotels    Hotel[]
  places    Place[]

  @@index([isActive, name])
  @@map("cities")
}

model Company {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  type         String?
  website      String?
  country      String?
  city         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  logoUrl      String?
  primaryColor String?
  branding     CompanyBranding?
  contacts     Contact[]
  leads        Lead[]
  brandQuotes  Quote[]          @relation("BrandQuotes")
  clientQuotes Quote[]          @relation("ClientQuotes")
  users        User[]

  @@map("companies")
}

model CompanyBranding {
  id             String   @id @default(uuid()) @db.Uuid
  companyId      String   @unique @db.Uuid
  displayName    String?
  logoUrl        String?
  headerTitle    String?
  headerSubtitle String?
  footerText     String?
  website        String?
  email          String?
  phone          String?
  primaryColor   String?
  secondaryColor String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_branding")
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  firstName String
  lastName  String
  email     String?
  phone     String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  quotes    Quote[]

  @@map("contacts")
}

model GalleryImage {
  id              String           @id @default(uuid()) @db.Uuid
  title           String
  imageUrl        String
  destination     String?
  category        String?
  createdAt       DateTime         @default(now())
  itineraryImages ItineraryImage[]

  @@map("gallery_images")
}

model HotelCategory {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  hotels       Hotel[]
  quoteOptions QuoteOption[]

  @@index([isActive, name])
  @@map("hotel_categories")
}

model HotelContract {
  id         String           @id @default(uuid()) @db.Uuid
  hotelId    String           @db.Uuid
  name       String
  validFrom  DateTime
  validTo    DateTime
  currency   String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  allotments HotelAllotment[]
  cancellationPolicy HotelContractCancellationPolicy?
  cancellationPolicyAuditLogs HotelContractCancellationAuditLog[]
  childPolicy HotelContractChildPolicy?
  mealPlanAuditLogs HotelContractMealPlanAuditLog[]
  mealPlans HotelContractMealPlan[]
  hotel      Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  occupancyAuditLogs HotelContractOccupancyAuditLog[]
  occupancyRules HotelContractOccupancyRule[]
  promotions Promotion[]
  rates      HotelRate[]
  supplementAuditLogs HotelContractSupplementAuditLog[]
  supplements HotelContractSupplement[]
  childPolicyAuditLogs HotelContractChildPolicyAuditLog[]
  quoteItems QuoteItem[]

  @@index([hotelId])
  @@map("hotel_contracts")
}

model HotelContractOccupancyRule {
  id              String             @id @default(uuid()) @db.Uuid
  hotelContractId String             @db.Uuid
  roomCategoryId  String?            @db.Uuid
  occupancyType   HotelOccupancyType
  minAdults       Int
  maxAdults       Int
  maxChildren     Int                @default(0)
  maxOccupants    Int
  isActive        Boolean            @default(true)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  auditLogs       HotelContractOccupancyAuditLog[]
  hotelContract   HotelContract      @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  roomCategory    HotelRoomCategory? @relation(fields: [roomCategoryId], references: [id], onDelete: SetNull)

  @@index([hotelContractId, occupancyType, isActive])
  @@index([hotelContractId, roomCategoryId, occupancyType, isActive])
  @@index([roomCategoryId, occupancyType])
  @@map("hotel_contract_occupancy_rules")
}

model HotelContractOccupancyAuditLog {
  id              String                 @id @default(uuid()) @db.Uuid
  hotelContractId String                 @db.Uuid
  occupancyRuleId String?                @db.Uuid
  action          String
  oldValue        String?
  newValue        String?
  note            String?
  actorUserId     String                 @db.Uuid
  actor           String?
  createdAt       DateTime               @default(now())
  hotelContract   HotelContract          @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  occupancyRule   HotelContractOccupancyRule? @relation(fields: [occupancyRuleId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, createdAt])
  @@index([occupancyRuleId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("hotel_contract_occupancy_audit_logs")
}

model HotelContractChildPolicy {
  id                 String                       @id @default(uuid()) @db.Uuid
  hotelContractId    String                       @unique @db.Uuid
  infantMaxAge       Int
  childMaxAge        Int
  notes              String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  auditLogs          HotelContractChildPolicyAuditLog[]
  hotelContract      HotelContract                @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  bands              HotelContractChildPolicyBand[]

  @@map("hotel_contract_child_policies")
}

model HotelContractChildPolicyBand {
  id              String                  @id @default(uuid()) @db.Uuid
  childPolicyId   String                  @db.Uuid
  label           String
  minAge          Int
  maxAge          Int
  chargeBasis     ChildPolicyChargeBasis
  chargeValue     Float?
  isActive        Boolean                 @default(true)
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  auditLogs       HotelContractChildPolicyAuditLog[]
  childPolicy     HotelContractChildPolicy @relation(fields: [childPolicyId], references: [id], onDelete: Cascade)

  @@index([childPolicyId, isActive, minAge, maxAge])
  @@map("hotel_contract_child_policy_bands")
}

model HotelContractChildPolicyAuditLog {
  id                 String                      @id @default(uuid()) @db.Uuid
  hotelContractId    String                      @db.Uuid
  childPolicyId      String?                     @db.Uuid
  childPolicyBandId  String?                     @db.Uuid
  action             String
  oldValue           String?
  newValue           String?
  note               String?
  actorUserId        String                      @db.Uuid
  actor              String?
  createdAt          DateTime                    @default(now())
  hotelContract      HotelContract               @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  childPolicy        HotelContractChildPolicy?   @relation(fields: [childPolicyId], references: [id], onDelete: Cascade)
  childPolicyBand    HotelContractChildPolicyBand? @relation(fields: [childPolicyBandId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, createdAt])
  @@index([childPolicyId, createdAt])
  @@index([childPolicyBandId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("hotel_contract_child_policy_audit_logs")
}

model HotelContractCancellationPolicy {
  id                 String                              @id @default(uuid()) @db.Uuid
  hotelContractId    String                              @unique @db.Uuid
  summary            String?
  notes              String?
  noShowPenaltyType  HotelCancellationPenaltyType?
  noShowPenaltyValue Float?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  auditLogs          HotelContractCancellationAuditLog[]
  hotelContract      HotelContract                       @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  rules              HotelContractCancellationRule[]

  @@map("hotel_contract_cancellation_policies")
}

model HotelContractCancellationRule {
  id                   String                              @id @default(uuid()) @db.Uuid
  cancellationPolicyId String                              @db.Uuid
  windowFromValue      Int
  windowToValue        Int
  deadlineUnit         HotelCancellationDeadlineUnit
  penaltyType          HotelCancellationPenaltyType
  penaltyValue         Float?
  isActive             Boolean                             @default(true)
  notes                String?
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt
  auditLogs            HotelContractCancellationAuditLog[]
  cancellationPolicy   HotelContractCancellationPolicy     @relation(fields: [cancellationPolicyId], references: [id], onDelete: Cascade)

  @@index([cancellationPolicyId, isActive, deadlineUnit, windowFromValue, windowToValue])
  @@map("hotel_contract_cancellation_rules")
}

model HotelContractCancellationAuditLog {
  id                    String                              @id @default(uuid()) @db.Uuid
  hotelContractId       String                              @db.Uuid
  cancellationPolicyId  String?                             @db.Uuid
  cancellationRuleId    String?                             @db.Uuid
  action                String
  oldValue              String?
  newValue              String?
  note                  String?
  actorUserId           String                              @db.Uuid
  actor                 String?
  createdAt             DateTime                            @default(now())
  hotelContract         HotelContract                       @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  cancellationPolicy    HotelContractCancellationPolicy?    @relation(fields: [cancellationPolicyId], references: [id], onDelete: Cascade)
  cancellationRule      HotelContractCancellationRule?      @relation(fields: [cancellationRuleId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, createdAt])
  @@index([cancellationPolicyId, createdAt])
  @@index([cancellationRuleId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("hotel_contract_cancellation_audit_logs")
}

model HotelContractMealPlan {
  id              String                     @id @default(uuid()) @db.Uuid
  hotelContractId String                     @db.Uuid
  code            HotelMealPlan
  isDefault       Boolean                    @default(false)
  isActive        Boolean                    @default(true)
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  auditLogs       HotelContractMealPlanAuditLog[]
  hotelContract   HotelContract              @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)

  @@unique([hotelContractId, code])
  @@index([hotelContractId, isDefault])
  @@index([hotelContractId, isActive])
  @@map("hotel_contract_meal_plans")
}

model HotelContractMealPlanAuditLog {
  id              String                @id @default(uuid()) @db.Uuid
  hotelContractId String                @db.Uuid
  mealPlanId      String?               @db.Uuid
  action          String
  oldValue        String?
  newValue        String?
  note            String?
  actorUserId     String                @db.Uuid
  actor           String?
  createdAt       DateTime              @default(now())
  hotelContract   HotelContract         @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  mealPlan        HotelContractMealPlan? @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, createdAt])
  @@index([mealPlanId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("hotel_contract_meal_plan_audit_logs")
}

model HotelContractSupplement {
  id              String                        @id @default(uuid()) @db.Uuid
  hotelContractId String                        @db.Uuid
  roomCategoryId  String?                       @db.Uuid
  type            HotelContractSupplementType
  chargeBasis     HotelContractChargeBasis
  amount          Float
  currency        String
  isMandatory     Boolean                       @default(false)
  isActive        Boolean                       @default(true)
  notes           String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  auditLogs       HotelContractSupplementAuditLog[]
  hotelContract   HotelContract                 @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  roomCategory    HotelRoomCategory?            @relation(fields: [roomCategoryId], references: [id], onDelete: SetNull)

  @@index([hotelContractId, type, isActive])
  @@index([hotelContractId, roomCategoryId])
  @@index([hotelContractId, roomCategoryId, type, isActive])
  @@index([roomCategoryId, type])
  @@map("hotel_contract_supplements")
}

model HotelContractSupplementAuditLog {
  id              String                     @id @default(uuid()) @db.Uuid
  hotelContractId String                     @db.Uuid
  supplementId    String?                    @db.Uuid
  action          String
  oldValue        String?
  newValue        String?
  note            String?
  actorUserId     String                     @db.Uuid
  actor           String?
  createdAt       DateTime                   @default(now())
  hotelContract   HotelContract              @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  supplement      HotelContractSupplement?   @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, createdAt])
  @@index([supplementId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("hotel_contract_supplement_audit_logs")
}

model HotelAllotment {
  id              String            @id @default(uuid()) @db.Uuid
  hotelContractId String            @db.Uuid
  roomCategoryId  String            @db.Uuid
  dateFrom        DateTime
  dateTo          DateTime
  allotment       Int
  releaseDays     Int               @default(0)
  stopSale        Boolean           @default(false)
  notes           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  hotelContract   HotelContract     @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  roomCategory    HotelRoomCategory @relation(fields: [roomCategoryId], references: [id], onDelete: Cascade)

  @@index([hotelContractId, dateFrom, dateTo])
  @@index([roomCategoryId, dateFrom, dateTo])
  @@index([isActive, dateFrom, dateTo])
  @@map("hotel_allotments")
}

model HotelRate {
  id             String             @id @default(uuid()) @db.Uuid
  contractId     String             @db.Uuid
  seasonId       String?            @db.Uuid
  seasonName     String
  mealPlan       HotelMealPlan
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  roomCategoryId String             @db.Uuid
  occupancyType  HotelOccupancyType
  currency       String
  cost           Float
  contract       HotelContract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  roomCategory   HotelRoomCategory  @relation(fields: [roomCategoryId], references: [id])
  season         Season?            @relation(fields: [seasonId], references: [id])

  @@index([contractId])
  @@index([seasonId])
  @@index([roomCategoryId])
  @@map("hotel_rates")
}

model Promotion {
  id              String          @id @default(uuid()) @db.Uuid
  hotelContractId String          @db.Uuid
  name            String
  type            PromotionType
  value           Float?
  stayPayNights   Int?
  payNights       Int?
  freeNightCount  Int?
  isActive        Boolean         @default(true)
  priority        Int             @default(0)
  combinabilityMode PromotionCombinabilityMode @default(EXCLUSIVE)
  promotionGroup  String?
  combinable      Boolean         @default(false)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  hotelContract   HotelContract   @relation(fields: [hotelContractId], references: [id], onDelete: Cascade)
  rules           PromotionRule[]

  @@index([hotelContractId, isActive, priority])
  @@map("promotions")
}

model PromotionRule {
  id              String             @id @default(uuid()) @db.Uuid
  promotionId     String             @db.Uuid
  roomCategoryId  String?            @db.Uuid
  travelDateFrom  DateTime?
  travelDateTo    DateTime?
  bookingDateFrom DateTime?
  bookingDateTo   DateTime?
  boardBasis      HotelMealPlan?
  minStay         Int?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  promotion       Promotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  roomCategory    HotelRoomCategory? @relation(fields: [roomCategoryId], references: [id], onDelete: SetNull)

  @@index([promotionId, isActive])
  @@index([roomCategoryId])
  @@index([travelDateFrom, travelDateTo])
  @@index([bookingDateFrom, bookingDateTo])
  @@map("promotion_rules")
}

model HotelRoomCategory {
  id             String           @id @default(uuid()) @db.Uuid
  hotelId        String           @db.Uuid
  name           String
  code           String?
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  allotments     HotelAllotment[]
  hotelRates     HotelRate[]
  hotel          Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  occupancyRules HotelContractOccupancyRule[]
  promotionRules PromotionRule[]
  quoteItems     QuoteItem[]
  supplements    HotelContractSupplement[]

  @@index([hotelId])
  @@map("hotel_room_categories")
}

model Hotel {
  id              String              @id @default(uuid()) @db.Uuid
  name            String
  city            String
  category        String
  supplierId      String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  cityId          String?             @db.Uuid
  hotelCategoryId String?             @db.Uuid
  contracts       HotelContract[]
  roomCategories  HotelRoomCategory[]
  cityRecord      City?               @relation(fields: [cityId], references: [id])
  hotelCategory   HotelCategory?      @relation(fields: [hotelCategoryId], references: [id])
  quoteItems      QuoteItem[]

  @@index([cityId])
  @@index([hotelCategoryId])
  @@map("hotels")
}

model Itinerary {
  id          String           @id @default(uuid()) @db.Uuid
  quoteId     String           @db.Uuid
  dayNumber   Int
  title       String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  quote       Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  images      ItineraryImage[]
  quoteItems  QuoteItem[]

  @@map("itineraries")
}

model ItineraryImage {
  id             String       @id @default(uuid()) @db.Uuid
  itineraryId    String       @db.Uuid
  galleryImageId String       @db.Uuid
  sortOrder      Int          @default(0)
  galleryImage   GalleryImage @relation(fields: [galleryImageId], references: [id], onDelete: Cascade)
  itinerary      Itinerary    @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([galleryImageId])
  @@index([itineraryId, sortOrder])
  @@map("itinerary_images")
}

model Lead {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String?   @db.Uuid
  assignedToId String?   @db.Uuid
  source       String?
  status       String    @default("new")
  inquiry      String
  travelDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  company      Company?  @relation(fields: [companyId], references: [id])

  @@map("leads")
}

model PlaceType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  places    Place[]

  @@index([isActive, name])
  @@map("place_types")
}

model Place {
  id               String        @id @default(uuid()) @db.Uuid
  name             String
  type             String
  city             String?
  country          String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cityId           String?       @db.Uuid
  placeTypeId      String?       @db.Uuid
  cityRecord       City?         @relation(fields: [cityId], references: [id])
  placeType        PlaceType?    @relation(fields: [placeTypeId], references: [id])
  fromRoutes       Route[]       @relation("RouteFromPlace")
  toRoutes         Route[]       @relation("RouteToPlace")
  fromVehicleRates VehicleRate[] @relation("VehicleRateFromPlace")
  toVehicleRates   VehicleRate[] @relation("VehicleRateToPlace")

  @@index([cityId])
  @@index([isActive, name])
  @@index([placeTypeId])
  @@map("places")
}

model QuoteBlock {
  id                   String           @id @default(uuid()) @db.Uuid
  name                 String
  type                 QuoteBlockType
  title                String
  description          String?
  defaultServiceId     String?          @db.Uuid
  defaultServiceTypeId String?          @db.Uuid
  defaultCategory      String?
  defaultCost          Float?
  defaultSell          Float?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  defaultService       SupplierService? @relation(fields: [defaultServiceId], references: [id])
  defaultServiceType   ServiceType?     @relation(fields: [defaultServiceTypeId], references: [id])

  @@index([defaultServiceId])
  @@index([defaultServiceTypeId])
  @@index([type, name])
  @@map("quote_blocks")
}

model QuoteItem {
  id                     String              @id @default(uuid()) @db.Uuid
  quoteId                String              @db.Uuid
  serviceId              String              @db.Uuid
  quantity               Int                 @default(1)
  paxCount               Int?
  participantCount       Int?
  adultCount             Int?
  childCount             Int?
  roomCount              Int?
  nightCount             Int?
  dayCount               Int?
  markupPercent          Float               @default(0)
  totalCost              Float
  totalSell              Float
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  appliedVehicleRateId   String?             @db.Uuid
  currency               String
  pricingDescription     String?
  itineraryId            String?             @db.Uuid
  serviceDate            DateTime?
  startTime              String?
  pickupTime             String?
  pickupLocation         String?
  meetingPoint           String?
  reconfirmationRequired Boolean             @default(false)
  reconfirmationDueAt    DateTime?
  optionId               String?             @db.Uuid
  hotelId                String?             @db.Uuid
  contractId             String?             @db.Uuid
  seasonName             String?
  mealPlan               HotelMealPlan?
