  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  leads          Lead[]
  assignedQuotes Quote[]  @relation("AssignedAgentQuotes")
  company        Company  @relation(fields: [companyId], references: [id])
  role           Role     @relation(fields: [roleId], references: [id])

  @@map("users")
}

model VehicleRate {
  id            String               @id @default(uuid()) @db.Uuid
  vehicleId     String               @db.Uuid
  serviceTypeId String               @db.Uuid
  supplierId    String?              @db.Uuid
  routeName     String
  minPax        Int
  maxPax        Int
  price         Float
  currency      String
  validFrom     DateTime
  validTo       DateTime
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  fromPlaceId   String?              @db.Uuid
  toPlaceId     String?              @db.Uuid
  routeId       String?              @db.Uuid
  quoteItems    QuoteItem[]
  fromPlace     Place?               @relation("VehicleRateFromPlace", fields: [fromPlaceId], references: [id])
  route         Route?               @relation(fields: [routeId], references: [id])
  serviceType   TransportServiceType @relation(fields: [serviceTypeId], references: [id])
  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  toPlace       Place?               @relation("VehicleRateToPlace", fields: [toPlaceId], references: [id])
  vehicle       Vehicle              @relation(fields: [vehicleId], references: [id])

  @@index([fromPlaceId])
  @@index([routeId])
  @@index([serviceTypeId, fromPlaceId, toPlaceId, minPax, maxPax], map: "vehicle_rates_serviceTypeId_fromPlaceId_toPlaceId_minPax_maxPax")
  @@index([serviceTypeId, routeId, minPax, maxPax])
  @@index([serviceTypeId, routeName, minPax, maxPax])
  @@index([supplierId])
  @@index([toPlaceId])
  @@index([vehicleId])
  @@map("vehicle_rates")
}

model Vehicle {
  id              String                 @id @default(uuid()) @db.Uuid
  supplierId      String
  resolvedSupplierId String?             @db.Uuid
  supplierName    String?
  name            String
  maxPax          Int
  luggageCapacity Int
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  vehicleRates    VehicleRate[]
  bookingServices BookingService[]
  pricingRules    TransportPricingRule[]

  @@map("vehicles")
}

model BookingService {
  id                      String                        @id @default(uuid()) @db.Uuid
  bookingId               String                        @db.Uuid
  bookingDayId            String?                       @db.Uuid
  sourceQuoteItemId       String?                       @db.Uuid
  activityId              String?                       @db.Uuid
  serviceOrder            Int                           @default(0)
  serviceType             String
  operationType           String?
  operationStatus         String                        @default("PENDING")
  referenceId             String?                       @db.Uuid
  assignedTo              String?
  guidePhone              String?
  vehicleId               String?                       @db.Uuid
  serviceDate             DateTime?
  startTime               String?
  pickupTime              String?
  pickupLocation          String?
  meetingPoint            String?
  participantCount        Int?
  adultCount              Int?
  childCount              Int?
  supplierReference       String?
  reconfirmationRequired  Boolean                       @default(false)
  reconfirmationDueAt     DateTime?
  description             String
  notes                   String?
  qty                     Int                           @default(1)
  unitCost                Float
  unitSell                Float
  totalCost               Float
  totalSell               Float
  status                  BookingServiceLifecycleStatus @default(pending)
  supplierId              String?                       @db.Uuid
  supplierName            String?
  confirmationStatus      BookingServiceStatus          @default(pending)
  confirmationNumber      String?
  confirmationNotes       String?
  statusNote              String?
  confirmationRequestedAt DateTime?
  confirmationConfirmedAt DateTime?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  booking                 Booking                       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingDay              BookingDay?                   @relation(fields: [bookingDayId], references: [id], onDelete: Cascade)
  activity                Activity?                     @relation(fields: [activityId], references: [id], onDelete: SetNull)
  auditLogs               BookingAuditLog[]
  vouchers                Voucher[]
  supplier                Supplier?                     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  vehicle                 Vehicle?                      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([bookingDayId])
  @@index([activityId])
  @@index([bookingId, serviceOrder])
  @@index([sourceQuoteItemId])
  @@index([supplierId])
  @@index([vehicleId])
  @@index([operationType, operationStatus])
  @@map("booking_services")
}

model BookingAuditLog {
  id               String                 @id @default(uuid()) @db.Uuid
  bookingId        String                 @db.Uuid
  bookingServiceId String?                @db.Uuid
  entityType       BookingAuditEntityType
  entityId         String                 @db.Uuid
  oldValue         String?
  newValue         String?
  action           String
  note             String?
  actorUserId      String?                @db.Uuid
  actor            String?
  createdAt        DateTime               @default(now())
  booking          Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingService   BookingService?        @relation(fields: [bookingServiceId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([bookingServiceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("booking_audit_logs")
}

model Voucher {
  id               String         @id @default(uuid()) @db.Uuid
  bookingId        String         @db.Uuid
  bookingServiceId String         @unique @db.Uuid
  type             VoucherType
  supplierId       String         @db.Uuid
  status           VoucherStatus  @default(DRAFT)
  issuedAt         DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  booking          Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingService   BookingService @relation(fields: [bookingServiceId], references: [id], onDelete: Cascade)
  supplier         Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
  @@index([supplierId])
  @@map("vouchers")
}

