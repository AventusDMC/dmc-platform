model Quote {
  id                  String             @id @default(uuid()) @db.Uuid
  clientCompanyId     String             @map("companyId") @db.Uuid
  contactId           String             @db.Uuid
  bookingType         BookingType        @default(FIT)
  title               String
  description         String?
  totalPrice          Float              @default(0)
  status              QuoteStatus        @default(DRAFT)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  adults              Int                @default(1)
  children            Int                @default(0)
  roomCount           Int                @default(1)
  nightCount          Int                @default(1)
  totalCost           Float              @default(0)
  totalSell           Float              @default(0)
  pricePerPax         Float              @default(0)
  acceptedVersionId   String?            @db.Uuid
  quoteNumber         String?            @unique
  clientChangeRequestMessage String?
  singleSupplement    Float?
  pricingType         String             @default("simple")
  focType             String             @default("none")
  focRatio            Float?
  focCount            Int?
  focRoomType         String?
  brandCompanyId      String?            @db.Uuid
  pricingMode         String             @default("FIXED")
  fixedPricePerPerson Float              @default(0)
  inclusionsText      String?
  exclusionsText      String?
  termsNotesText      String?
  travelStartDate     DateTime?
  validUntil          DateTime?
  sentAt              DateTime?
  acceptedAt          DateTime?
  publicToken         String?            @unique
  publicEnabled       Boolean            @default(false)
  booking             Booking?
  invoice             Invoice?
  invoiceAuditLogs    InvoiceAuditLog[]
  itineraries         Itinerary[]
  itineraryDays       QuoteItineraryDay[]
  itineraryAuditLogs  QuoteItineraryAuditLog[]
  quoteItems          QuoteItem[]
  quoteOptions        QuoteOption[]
  pricingSlabs        QuotePricingSlab[]
  scenarios           QuoteScenario[]
  versions            QuoteVersion[]     @relation("QuoteVersions")
  acceptedVersion     QuoteVersion?      @relation("AcceptedQuoteVersion", fields: [acceptedVersionId], references: [id])
  brandCompany        Company?           @relation("BrandQuotes", fields: [brandCompanyId], references: [id])
  clientCompany       Company            @relation("ClientQuotes", fields: [clientCompanyId], references: [id])
  contact             Contact            @relation(fields: [contactId], references: [id])

  @@index([bookingType])
  @@index([brandCompanyId])
  @@map("quotes")
}

